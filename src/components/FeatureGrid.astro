---
import {
  Bot,
  Braces,
  ClipboardList,
  FileDiff,
  FolderGit2,
  Keyboard,
  MonitorCog,
  PanelsTopLeft,
  RefreshCcw,
} from '@lucide/astro';

// @spec: cap-product-homepage/screenshot-led-workflow-story#understand-the-end-to-end-workflow
const featureGroups = [
  {
    number: '01',
    title: 'Agent workspace',
    summary: 'Choose the right agent and keep each task’s context separate.',
    features: [
      {
        icon: PanelsTopLeft,
        title: 'Parallel sessions, isolated context',
        body: 'Give every task its own history, model, permission mode, and working directory.',
      },
      {
        icon: MonitorCog,
        title: 'Agent setup without JSON editing',
        body: 'Browse the registry, add agents, reorder them, test commands, and manage updates visually.',
      },
      {
        icon: Bot,
        title: 'ACP-native, not provider-locked',
        body: 'Bring any Agent Client Protocol implementation into the same VS Code workspace.',
      },
    ],
  },
  {
    number: '02',
    title: 'Visible execution',
    summary: 'Follow the plan, inspect the evidence, and keep results readable.',
    features: [
      {
        icon: ClipboardList,
        title: 'Plans stay readable',
        body: 'Track execution in a task panel while reasoning stays in a separate expandable block.',
      },
      {
        icon: FileDiff,
        title: 'Tool work you can inspect',
        body: 'Follow tool calls as they stream, with clear status, changed-line totals, and inline diffs.',
      },
      {
        icon: Braces,
        title: 'Results keep their useful shape',
        body: 'Review Markdown, code, images, audio, diffs, resources, and links in the timeline.',
      },
    ],
  },
  {
    number: '03',
    title: 'Continuity and control',
    summary: 'Keep the codebase attached and recover without rebuilding the session.',
    features: [
      {
        icon: FolderGit2,
        title: 'Codebase context stays attached',
        body: 'Keep each tab’s cwd, branch, staged changes, stash, and ahead/behind state visible.',
      },
      {
        icon: Keyboard,
        title: 'Prompt from where you code',
        body: 'Use commands and skills, mention files or line ranges, attach context, or send a selection.',
      },
      {
        icon: RefreshCcw,
        title: 'Sessions recover gracefully',
        body: 'Restore tabs after reloads, replay history, or start fresh when an agent drops a session.',
      },
    ],
  },
];
---

<section id="features" class="section features">
  <div class="page-shell">
    <div class="section-heading">
      <p class="eyebrow">Built for daily work</p>
      <h2>Depth where the workflow needs it.</h2>
      <p>
        The screenshots show the flow. Underneath it, ACP Pro keeps agent choice,
        execution evidence, codebase state, and recovery organized for repeated use.
      </p>
    </div>

    <div class="feature-groups">
      {
        featureGroups.map((group) => (
          <article class="feature-group surface">
            <header class="feature-group-heading">
              <span aria-hidden="true">{group.number}</span>
              <h3>{group.title}</h3>
              <p>{group.summary}</p>
            </header>
            <div class="feature-list">
              {group.features.map((feature) => {
                const Icon = feature.icon;
                return (
                  <div class="feature-item">
                    <Icon size={21} aria-hidden="true" />
                    <div>
                      <h4>{feature.title}</h4>
                      <p>{feature.body}</p>
                    </div>
                  </div>
                );
              })}
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .features {
    padding-top: 74px;
  }

  .feature-groups {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
    margin-top: 36px;
  }

  .feature-group {
    min-width: 0;
    padding: clamp(22px, 3vw, 30px);
  }

  .feature-group-heading span {
    display: inline-flex;
    min-width: 2.2rem;
    min-height: 2.2rem;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    color: var(--blue);
    background: rgba(36, 107, 254, 0.08);
    font-size: 0.74rem;
    font-weight: 900;
  }

  .feature-group-heading h3 {
    margin: 18px 0 0;
    font-size: clamp(1.3rem, 2.2vw, 1.72rem);
    line-height: 1.05;
  }

  .feature-group-heading p {
    margin: 10px 0 0;
    color: var(--muted);
  }

  .feature-list {
    display: grid;
    margin-top: 24px;
  }

  .feature-item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 12px;
    border-top: 1px solid var(--line);
    padding: 18px 0;
  }

  .feature-item:last-child {
    padding-bottom: 0;
  }

  .feature-item svg {
    margin-top: 2px;
    color: var(--blue);
  }

  .feature-item h4 {
    margin: 0;
    font-size: 1rem;
    line-height: 1.2;
  }

  .feature-item p {
    margin: 7px 0 0;
    color: var(--muted);
    font-size: 0.91rem;
  }

  @media (max-width: 960px) {
    .feature-groups {
      grid-template-columns: 1fr;
    }

    .feature-group {
      display: grid;
      grid-template-columns: minmax(220px, 0.44fr) minmax(0, 1fr);
      gap: 28px;
    }

    .feature-list {
      margin-top: 0;
    }
  }

  @media (max-width: 660px) {
    .feature-group {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .feature-list {
      margin-top: 24px;
    }
  }
</style>
