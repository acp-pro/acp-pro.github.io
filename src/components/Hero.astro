---
import { ArrowUpRight, Download } from '@lucide/astro';
---

<section class="hero">
  <div class="page-shell hero-grid">
    <div class="hero-copy">
      <p class="eyebrow">VS Code extension · Agent Client Protocol</p>
      <h1>One ACP Client for every AI agent.</h1>
      <p class="hero-lede">
        ACP Pro gives VS Code a unified, tabbed chat interface for Claude Code,
        Codex CLI, GitHub Copilot CLI, Gemini CLI, Qwen Code, OpenCode, and any
        ACP-compatible agent.
      </p>
    </div>

    <div class="hero-visual" aria-label="ACP Pro product preview">
      <div class="window dark-surface">
        <img
          src="/assets/acp-pro-demo.gif"
          alt="ACP Pro multi-tab chat with streamed tool calls and inline diffs"
          loading="eager"
          decoding="async"
        />
      </div>
      <div class="hero-actions">
        <a
          class="button button-primary"
          href="https://marketplace.visualstudio.com/items?itemName=duclvz.acp-pro"
        >
          <Download size={18} aria-hidden="true" />
          Install from Marketplace
          <ArrowUpRight size={16} aria-hidden="true" />
        </a>
        <a
          class="button button-ghost"
          href="https://open-vsx.org/extension/duclvz/acp-pro"
        >
          <Download size={18} aria-hidden="true" />
          Install from Open VSX
          <ArrowUpRight size={16} aria-hidden="true" />
        </a>
      </div>
      <p class="compat-note">
        Open VSX supports VS Code-compatible IDEs including Cursor, Windsurf,
        Trae, and similar editors.
      </p>
      <dl class="hero-stats" aria-label="Marketplace stats">
        <div>
          <dt>Version</dt>
          <dd>0.2.1</dd>
        </div>
        <div>
          <dt>Rating</dt>
          <dd>5.0</dd>
        </div>
        <div>
          <dt>Installs</dt>
          <dd>2K+</dd>
        </div>
      </dl>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: clamp(54px, 8vw, 112px) 0 28px;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.88fr) minmax(420px, 1.12fr);
    align-items: center;
    gap: clamp(34px, 6vw, 76px);
  }

  .hero-copy h1 {
    max-width: 760px;
    margin: 14px 0 0;
    font-size: clamp(2.7rem, 6.4vw, 6rem);
    line-height: 0.92;
    letter-spacing: 0;
  }

  .hero-lede {
    max-width: 670px;
    margin: 24px 0 0;
    color: var(--muted);
    font-size: clamp(1.08rem, 2vw, 1.32rem);
  }

  .hero-actions {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
    margin-top: 14px;
  }

  .compat-note {
    margin: 12px 0 0;
    color: var(--muted);
    font-size: 0.94rem;
  }

  .hero-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    margin: 22px 0 0;
  }

  .hero-stats div {
    border-left: 2px solid var(--line);
    padding-left: 14px;
  }

  .hero-stats dt {
    color: var(--muted);
    font-size: 0.76rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .hero-stats dd {
    margin: 2px 0 0;
    font-size: 1.65rem;
    font-weight: 900;
  }

  .hero-visual {
    min-width: 0;
  }

  .window {
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .window img {
    width: 100%;
    height: 100%;
    min-height: 0;
    object-fit: cover;
    background: #0c0f12;
  }

  @media (max-width: 980px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 620px) {
    .hero {
      padding-top: 36px;
    }

    .hero-actions {
      grid-template-columns: 1fr;
    }

    .hero-stats {
      grid-template-columns: 1fr;
    }

  }
</style>
