---
import { ArrowUpRight, Check, KeyRound } from '@lucide/astro';

const included = [
  'Core ACP chat experience remains free',
  'Persistent custom browser access code',
  'Owner password for browser control',
  'Read-only/full-write browser toggle',
  'One activation across a VS Code client profile',
  'Offline-resilient validated license state',
];
---

<!-- @spec: cap-product-homepage/screenshot-led-workflow-story#understand-remote-access-beyond-teammate-sharing -->
<section id="license" class="section license">
  <div class="page-shell license-grid">
    <div class="license-card dark-surface">
      <KeyRound size={28} aria-hidden="true" />
      <h2>Free to use. Pro adds control for browser access.</h2>
      <p>
        Every core agent workflow stays free. A Pro activation follows your VS
        Code client profile across local and remote workspaces while protected
        host keys keep the browser-access entitlement bound to approved environments.
      </p>
      <a class="button button-primary" href="https://duclvz.gumroad.com/l/acp-pro">
        Get a Pro license
        <ArrowUpRight size={16} aria-hidden="true" />
      </a>
    </div>
    <div class="included surface">
      <p class="eyebrow">What Pro adds</p>
      <ul>
        {
          included.map((item) => (
            <li>
              <Check size={18} aria-hidden="true" />
              <span>{item}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>

<style>
  .license-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(300px, 0.66fr);
    gap: 14px;
  }

  .license-card,
  .included {
    padding: clamp(24px, 5vw, 42px);
  }

  .license-card svg {
    color: var(--accent);
  }

  .license-card h2 {
    max-width: 760px;
    margin: 26px 0 0;
    font-size: clamp(2rem, 5vw, 4.7rem);
    line-height: 0.98;
    letter-spacing: 0;
  }

  .license-card p {
    max-width: 660px;
    margin: 22px 0 0;
    color: #b9bec3;
    font-size: 1.08rem;
  }

  .license-card .button {
    margin-top: 30px;
  }

  .included ul {
    display: grid;
    gap: 18px;
    margin: 22px 0 0;
    padding: 0;
    list-style: none;
  }

  .included li {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 10px;
    align-items: start;
    color: var(--ink);
    font-weight: 750;
  }

  .included li svg {
    color: var(--blue);
  }

  @media (max-width: 820px) {
    .license-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
